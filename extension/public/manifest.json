{
  "manifest_version": 3,
  "name": "OpenLink",
  "version": "1.0.0",
  "description": "OpenLink 代理 - 连接 AI 与本地环境",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["http://127.0.0.1:*/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.gemini.google.com/*",
        "*://aistudio.google.com/*",
        "*://*.chatgpt.com/*",
        "*://*.grok.com/*",
        "*://*.x.com/*",
        "*://*.kimi.com/*",
        "*://*.chat.mistral.ai/*",
        "*://*.perplexity.ai/*",
        "*://*.openrouter.ai/*",
        "*://*.qwen.ai/*",
        "*://*.t3.chat/*",
        "*://*.github.com/*",
        "*://*.z.ai/*",
        "*://*.arena.ai/*",
        "*://*.deepseek.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": [
        "*://*.gemini.google.com/*",
        "*://aistudio.google.com/*",
        "*://*.chatgpt.com/*",
        "*://*.grok.com/*",
        "*://*.x.com/*",
        "*://*.kimi.com/*",
        "*://*.chat.mistral.ai/*",
        "*://*.perplexity.ai/*",
        "*://*.openrouter.ai/*",
        "*://*.qwen.ai/*",
        "*://*.t3.chat/*",
        "*://*.github.com/*",
        "*://*.z.ai/*",
        "*://*.arena.ai/*",
        "*://*.deepseek.com/*"
      ]
    }
  ]
}
